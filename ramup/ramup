# ─── Logging ──────────────────────────────────────────────────────────────────
log() {
    local level="$1"
    shift
    local msg="$*"
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    mkdir -p "$(dirname "$RAMUP_LOG")"
    echo "[${timestamp}] [${level}] ${msg}" >> "$RAMUP_LOG"
    
    if [[ "${QUIET:-0}" != "1" ]]; then
        case "$level" in
            INFO)  echo -e "${GREEN}[✓]${NC} ${msg}" ;;
            WARN)  echo -e "${YELLOW}[!]${NC} ${msg}" ;;
            ERROR) echo -e "${RED}[✗]${NC} ${msg}" ;;
            OK)    echo -e "${GREEN}[✓]${NC} ${msg}" ;;
            DEBUG) [[ "${VERBOSE:-0}" == "1" ]] && echo -e "${DIM}[·] ${msg}${NC}" ;;
            *)     echo -e "${msg}" ;;
        esac
    fi
}

# ─── Root Check ───────────────────────────────────────────────────────────────
require_root() {
    if [[ $EUID -ne 0 ]]; then
        log ERROR "This command requires root privileges"
        echo -e "${YELLOW}Try: sudo ramup $1${NC}"
        exit 1
    fi
}

# ─── Parse Arguments ──────────────────────────────────────────────────────────
FORCE=0
QUIET=0
VERBOSE=0
DRY_RUN=0
AGGRESSIVE=0
SAFE_MODE=0
JSON_OUTPUT=0

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)      FORCE=1 ;;
            --quiet)      QUIET=1 ;;
            --verbose)    VERBOSE=1 ;;
            --dry-run)    DRY_RUN=1 ;;
            --aggressive) AGGRESSIVE=1 ;;
            --safe)       SAFE_MODE=1 ;;
            --json)       JSON_OUTPUT=1 ;;
            *)            ;;
        esac
        shift
    done
}

