cmd_install() {
    show_logo
    require_root "install"
    
    echo -e "${CYAN}${BOLD}  Starting ramup installation...${NC}"
    echo ""
    
    # Step 1: System detection
    log INFO "Detecting system specifications..."
    detect_system
    echo -e "  ${DIM}├─${NC} RAM: ${WHITE}${TOTAL_RAM_MB}MB${NC} | CPU: ${WHITE}${CPU_CORES} cores${NC} | Distro: ${WHITE}${DISTRO}${NC}"
    echo -e "  ${DIM}├─${NC} Kernel: ${WHITE}${KERNEL_VERSION}${NC} | SSD: ${WHITE}$([[ $HAS_SSD -eq 1 ]] && echo "Yes ✓" || echo "No")${NC}"
    echo -e "  ${DIM}└─${NC} Architecture: ${WHITE}$(uname -m)${NC} | Virt: ${WHITE}$(systemd-detect-virt 2>/dev/null || echo "bare-metal")${NC}"
    echo ""
    
    # Step 2: Safety backup
    log INFO "Creating safety backup..."
    create_backup "pre-install"
    
    # Step 3: Install ZRAM
    log INFO "Configuring ZRAM engine..."
    setup_zram
    
    # Step 4: Setup smart swap
    log INFO "Setting up smart swap..."
    setup_swap
    
    # Step 5: Tune kernel
    log INFO "Optimizing kernel parameters..."
    tune_kernel
    
    # Step 6: Optimize system
    log INFO "Optimizing system services..."
    optimize_system
    
    # Step 7: Docker optimization (if Docker present)
    if command -v docker &>/dev/null; then
        log INFO "Optimizing Docker memory..."
        optimize_docker
    fi
    
    # Step 8: Setup auto-adjust
    log INFO "Enabling intelligent auto-adjust..."
    setup_autoadjust
    
    # Step 9: Save state
    save_state "active"
    
    echo ""
    echo -e "${GREEN}${BOLD}  ════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}${BOLD}            🎉 Installation Complete! 🎉             ${NC}"
    echo -e "${GREEN}${BOLD}  ════════════════════════════════════════════════════${NC}"
    echo ""
    show_memory_summary
    echo ""
    echo -e "  ${DIM}Commands:${NC} ramup status | monitor | tune | help"
    echo ""
}

cmd_uninstall() {
    show_mini_logo
    require_root "uninstall"
    
    log WARN "Uninstalling ramup..."
    
    stop_autoadjust
    disable_zram
    remove_swap
    restore_kernel
    
    if [[ -d "$RAMUP_BACKUP/latest" ]]; then
        log INFO "Restoring from backup..."
        restore_backup "latest"
    fi
    
    save_state "inactive"
    log INFO "ramup uninstalled. System restored to defaults."
}

