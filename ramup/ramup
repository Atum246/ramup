}

cmd_monitor() {
    start_monitor
}

cmd_on() {
    require_root "on"
    
    if [[ "$(get_state)" == "active" ]]; then
        log INFO "ramup is already active"
        return 0
    fi
    
    log INFO "Enabling ramup..."
    setup_zram
    setup_swap
    tune_kernel
    save_state "active"
    log OK "ramup enabled ✅"
}

cmd_off() {
    require_root "off"
    
    if [[ "$(get_state)" != "active" ]]; then
        log INFO "ramup is not active"
        return 0
    fi
    
    log INFO "Disabling ramup..."
    disable_zram
    remove_swap
    restore_kernel
    save_state "inactive"
    log INFO "ramup disabled. Memory restored to defaults."
}

