#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════
# 🟢 RAMUP — Your 4GB just became 7GB
# ═══════════════════════════════════════════════════════════
# Advanced VPS memory extension tool
# Safe. Simple. Powerful.
# ═══════════════════════════════════════════════════════════

set -uo pipefail

VERSION="1.0.0"
RAMUP_DIR="${RAMUP_DIR:-/opt/ramup}"
RAMUP_LOG="${RAMUP_DIR}/logs/ramup.log"
RAMUP_BACKUP="${RAMUP_DIR}/backups"
RAMUP_STATE="${RAMUP_DIR}/state.json"
RAMUP_CONFIG="${RAMUP_DIR}/config.conf"

# ─── Colors ───────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Source Libraries ─────────────────────────────────────
for lib in core zram swap kernel cleanup monitor autoadjust safety; do
    lib_file="${RAMUP_DIR}/lib/${lib}.sh"
    if [[ -f "$lib_file" ]]; then
        source "$lib_file"
    fi
done

# ─── Version Info ─────────────────────────────────────────
show_version() {
    echo -e "${GREEN}${BOLD}ramup${NC} v${VERSION}"
    echo -e "${DIM}Advanced VPS memory extension tool${NC}"
}

# ─── Help ─────────────────────────────────────────────────
show_help() {
    cat << 'EOF'

  ╔═══════════════════════════════════════════════════╗
  ║           🟢 R A M U P  v1.0.0 🟢               ║
  ║       "Your 4GB just became 7GB"                 ║
  ╚═══════════════════════════════════════════════════╝

  USAGE:
    ramup <command> [options]

  COMMANDS:
    install         Install and activate ramup
    uninstall       Remove ramup and restore defaults
    status          Show current memory status
    monitor         Live memory dashboard
    on              Enable all ramup features
    off             Disable all ramup features
    config          Show current configuration
    tune            Auto-tune for current workload
    health          Run system health check
    logs            View recent logs
    backup          Create manual backup
    restore         Restore from backup
    benchmark       Test memory performance
    help            Show this help
    version         Show version

  OPTIONS:
    --force         Skip confirmations
    --quiet         Minimal output
    --verbose       Extra logging
    --dry-run       Show what would be done

  EXAMPLES:
    ramup install           Install and activate
    ramup status            Check memory status
    ramup monitor           Live dashboard
    ramup tune --aggressive Max performance mode
    ramup off               Disable everything safely

EOF
}

# ─── Logging ──────────────────────────────────────────────
log() {
    local level="$1"
    shift
    local msg="$*"
    local timestamp
    timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    
    # Write to log file
    mkdir -p "$(dirname "$RAMUP_LOG")"
    echo "[${timestamp}] [${level}] ${msg}" >> "$RAMUP_LOG"
    
    # Console output (unless quiet)
    if [[ "${QUIET:-0}" != "1" ]]; then
        case "$level" in
            INFO)  echo -e "${GREEN}[✓]${NC} ${msg}" ;;
            WARN)  echo -e "${YELLOW}[!]${NC} ${msg}" ;;
            ERROR) echo -e "${RED}[✗]${NC} ${msg}" ;;
            DEBUG) [[ "${VERBOSE:-0}" == "1" ]] && echo -e "${DIM}[·] ${msg}${NC}" ;;
            *)     echo -e "${msg}" ;;
        esac
    fi
}

# ─── Banner ───────────────────────────────────────────────
show_banner() {
    echo -e "${GREEN}${BOLD}"
    cat << 'EOF'
    ╔═══════════════════════════════════════╗
    ║         🟢  R A M U P  🟢           ║
    ║                                       ║
    ║    "Your 4GB just became 7GB"        ║
    ║                                       ║
    ╚═══════════════════════════════════════╝
EOF
    echo -e "${NC}"
}

# ─── Root Check ───────────────────────────────────────────
require_root() {
    if [[ $EUID -ne 0 ]]; then
        log ERROR "This command requires root privileges"
        echo -e "${YELLOW}Try: sudo ramup $1${NC}"
        exit 1
    fi
}

# ─── Parse Arguments ──────────────────────────────────────
FORCE=0
QUIET=0
VERBOSE=0
DRY_RUN=0
AGGRESSIVE=0

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)      FORCE=1 ;;
            --quiet)      QUIET=1 ;;
            --verbose)    VERBOSE=1 ;;
            --dry-run)    DRY_RUN=1 ;;
            --aggressive) AGGRESSIVE=1 ;;
            *)            ;;
        esac
        shift
    done
}

# ─── Main Commands ────────────────────────────────────────

cmd_install() {
    show_banner
    require_root "install"
    
    log INFO "Starting ramup installation..."
    
    # Step 1: System detection
    log INFO "Detecting system specs..."
    detect_system
    
    # Step 2: Safety backup
    log INFO "Creating safety backup..."
    create_backup "pre-install"
    
    # Step 3: Install ZRAM
    log INFO "Configuring ZRAM engine..."
    setup_zram
    
    # Step 4: Setup smart swap
    log INFO "Setting up smart swap..."
    setup_swap
    
    # Step 5: Tune kernel
    log INFO "Optimizing kernel parameters..."
    tune_kernel
    
    # Step 6: Cleanup memory
    log INFO "Cleaning up memory hogs..."
    cleanup_memory
    
    # Step 7: Setup auto-adjust
    log INFO "Enabling auto-adjust daemon..."
    setup_autoadjust
    
    # Step 8: Save state
    save_state "active"
    
    echo ""
    log INFO "${GREEN}${BOLD}ramup installed successfully! 🎉${NC}"
    echo ""
    show_memory_summary
    echo ""
    echo -e "${DIM}Run 'ramup monitor' to see live stats${NC}"
    echo -e "${DIM}Run 'ramup off' to disable safely${NC}"
}

cmd_uninstall() {
    show_banner
    require_root "uninstall"
    
    log WARN "Uninstalling ramup..."
    
    # Stop auto-adjust
    stop_autoadjust
    
    # Disable ZRAM
    disable_zram
    
    # Remove swap
    remove_swap
    
    # Restore kernel
    restore_kernel
    
    # Restore from backup if available
    if [[ -d "$RAMUP_BACKUP/latest" ]]; then
        log INFO "Restoring from backup..."
        restore_backup "latest"
    fi
    
    save_state "inactive"
    
    log INFO "ramup uninstalled. System restored to defaults."
}

cmd_status() {
    detect_system
    show_memory_summary
}

cmd_monitor() {
    start_monitor
}

cmd_on() {
    require_root "on"
    
    if [[ "$(get_state)" == "active" ]]; then
        log INFO "ramup is already active"
        return 0
    fi
    
    log INFO "Enabling ramup..."
    setup_zram
    setup_swap
    tune_kernel
    save_state "active"
    log INFO "ramup enabled ✅"
}

cmd_off() {
    require_root "off"
    
    if [[ "$(get_state)" != "active" ]]; then
        log INFO "ramup is not active"
        return 0
    fi
    
    log INFO "Disabling ramup..."
    disable_zram
    remove_swap
    restore_kernel
    save_state "inactive"
    log INFO "ramup disabled. Memory restored to defaults."
}

cmd_config() {
    echo -e "${CYAN}${BOLD}Current Configuration:${NC}"
    echo ""
    
    if [[ -f "$RAMUP_CONFIG" ]]; then
        cat "$RAMUP_CONFIG"
    else
        echo -e "${DIM}No config found. Run 'ramup install' first.${NC}"
    fi
}

cmd_tune() {
    require_root "tune"
    log INFO "Auto-tuning for current workload..."
    auto_tune
    log INFO "Tuning complete ✅"
}

cmd_health() {
    run_health_check
}

cmd_logs() {
    if [[ -f "$RAMUP_LOG" ]]; then
        tail -50 "$RAMUP_LOG"
    else
        echo -e "${DIM}No logs yet.${NC}"
    fi
}

cmd_backup() {
    require_root "backup"
    create_backup "manual"
    log INFO "Backup created ✅"
}

cmd_restore() {
    require_root "restore"
    if [[ -d "$RAMUP_BACKUP/latest" ]]; then
        restore_backup "latest"
        log INFO "Restored from backup ✅"
    else
        log ERROR "No backup found"
        exit 1
    fi
}

cmd_benchmark() {
    run_benchmark
}

# ─── State Management ─────────────────────────────────────
save_state() {
    local state="$1"
    mkdir -p "$(dirname "$RAMUP_STATE")"
    cat > "$RAMUP_STATE" << EOF
{
    "state": "${state}",
    "version": "${VERSION}",
    "installed_at": "$(date -Iseconds)",
    "hostname": "$(hostname)",
    "ram_mb": "$(get_total_ram_mb)"
}
EOF
}

get_state() {
    if [[ -f "$RAMUP_STATE" ]]; then
        grep -o '"state": *"[^"]*"' "$RAMUP_STATE" | cut -d'"' -f4
    else
        echo "inactive"
    fi
}

# ─── Memory Summary ───────────────────────────────────────
show_memory_summary() {
    local total_ram
    local zram_size
    local swap_size
    local effective
    
    total_ram=$(get_total_ram_mb)
    zram_size=$(get_zram_size_mb 2>/dev/null || echo "0")
    swap_size=$(get_swap_size_mb 2>/dev/null || echo "0")
    effective=$((total_ram + zram_size + swap_size))
    
    echo -e "${CYAN}┌──────────────────────────────────┐${NC}"
    echo -e "${CYAN}│${NC}  🟢 ${BOLD}RAMUP Status${NC}                 ${CYAN}│${NC}"
    echo -e "${CYAN}├──────────────────────────────────┤${NC}"
    printf "${CYAN}│${NC}  Physical RAM:   ${WHITE}%-6s MB${NC}       ${CYAN}│${NC}\n" "$total_ram"
    printf "${CYAN}│${NC}  ZRAM Active:    ${GREEN}%-6s MB${NC}       ${CYAN}│${NC}\n" "$zram_size"
    printf "${CYAN}│${NC}  Swap File:      ${GREEN}%-6s MB${NC}       ${CYAN}│${NC}\n" "$swap_size"
    echo -e "${CYAN}│${NC}  ${DIM}───────────────────────────${NC}    ${CYAN}│${NC}"
    printf "${CYAN}│${NC}  Effective RAM:  ${GREEN}${BOLD}~%-5s MB${NC}  🚀  ${CYAN}│${NC}\n" "$effective"
    local gain=$((effective - total_ram))
    printf "${CYAN}│${NC}  RAM Gained:     ${GREEN}+%-5s MB${NC}  📈  ${CYAN}│${NC}\n" "$gain"
    echo -e "${CYAN}└──────────────────────────────────┘${NC}"
}

# ─── Adjust Daemon ─────────────────────────────────────────
run_adjust_daemon() {
    log INFO "Starting RAMUP auto-adjust daemon..."
    
    while true; do
        local total free used pct
        total=$(get_total_ram_mb)
        free=$(get_available_ram_mb)
        used=$((total - free))
        pct=$((used * 100 / total))
        
        if [[ $pct -gt 90 ]]; then
            # CRITICAL: Maximum compression, drop caches
            sysctl -w vm.swappiness=5 >/dev/null 2>&1
            sysctl -w vm.vfs_cache_pressure=300 >/dev/null 2>&1
            sync
            echo 3 > /proc/sys/vm/drop_caches 2>/dev/null || true
            log WARN "CRITICAL memory pressure (${pct}%) — maximum recovery active"
        elif [[ $pct -gt 75 ]]; then
            # HIGH: Aggressive swap
            sysctl -w vm.swappiness=20 >/dev/null 2>&1
            sysctl -w vm.vfs_cache_pressure=200 >/dev/null 2>&1
            log DEBUG "High memory pressure (${pct}%) — aggressive mode"
        elif [[ $pct -gt 50 ]]; then
            # MODERATE: Balanced
            sysctl -w vm.swappiness=10 >/dev/null 2>&1
            sysctl -w vm.vfs_cache_pressure=150 >/dev/null 2>&1
        else
            # LOW: Relaxed
            sysctl -w vm.swappiness=10 >/dev/null 2>&1
            sysctl -w vm.vfs_cache_pressure=100 >/dev/null 2>&1
        fi
        
        sleep 60
    done
}

# ─── Main ─────────────────────────────────────────────────
main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true
    
    parse_args "$@"
    
    case "$cmd" in
        install)    cmd_install ;;
        uninstall)  cmd_uninstall ;;
        status)     cmd_status ;;
        monitor)    cmd_monitor ;;
        on)         cmd_on ;;
        off)        cmd_off ;;
        config)     cmd_config ;;
        tune)       cmd_tune ;;
        health)     cmd_health ;;
        logs)       cmd_logs ;;
        backup)     cmd_backup ;;
        restore)    cmd_restore ;;
        benchmark)  cmd_benchmark ;;
        adjust-daemon) run_adjust_daemon ;;
        version)    show_version ;;
        help|--help|-h) show_help ;;
        *)
            log ERROR "Unknown command: $cmd"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
