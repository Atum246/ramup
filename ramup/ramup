# MAIN
# ═══════════════════════════════════════════════════════════════════════════════

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true
    
    parse_args "$@"
    
    case "$cmd" in
        install)        cmd_install ;;
        uninstall)      cmd_uninstall ;;
        status)         cmd_status ;;
        monitor)        cmd_monitor ;;
        on)             cmd_on ;;
        off)            cmd_off ;;
        config)         cmd_config ;;
        tune)           cmd_tune ;;
        optimize)       cmd_optimize ;;
        profile)        cmd_profile "$@" ;;
        fix)            cmd_fix ;;
        boost)          cmd_boost ;;
        analyze)        cmd_analyze ;;
        predict)        cmd_predict ;;
        watch)          cmd_watch "$@" ;;
        top)            cmd_top ;;
        docker-opt)     cmd_docker_opt ;;
        docker-limit)   cmd_docker_limit "$@" ;;
        docker-stats)   cmd_docker_stats ;;
        health)         cmd_health ;;
        benchmark)      cmd_benchmark ;;
        sysinfo)        cmd_sysinfo ;;
        services)       cmd_services ;;
        backup)         cmd_backup ;;
        restore)        cmd_restore ;;
        logs)           cmd_logs ;;
        rollback)       cmd_rollback ;;
        daemon-start)   cmd_daemon_start ;;
        daemon-stop)    cmd_daemon_stop ;;
        daemon-status)  cmd_daemon_status ;;
        adjust-daemon)  run_adjust_daemon ;;
        version)        show_version ;;
        help|--help|-h) show_help ;;
        *)
            log ERROR "Unknown command: $cmd"
            echo ""
            echo -e "${DIM}Run 'ramup help' for available commands${NC}"
            exit 1
            ;;
    esac
}

main "$@"
