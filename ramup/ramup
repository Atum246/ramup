# ═══════════════════════════════════════════════════════════════════════════════
# STATE MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════════

save_state() {
    local state="$1"
    mkdir -p "$(dirname "$RAMUP_STATE")"
    cat > "$RAMUP_STATE" << EOF
{
    "state": "${state}",
    "version": "${VERSION}",
    "installed_at": "$(date -Iseconds)",
    "hostname": "$(hostname)",
    "ram_mb": "$(get_total_ram_mb)",
    "distro": "${DISTRO:-unknown}",
    "kernel": "$(uname -r)"
}
EOF
}

get_state() {
    if [[ -f "$RAMUP_STATE" ]]; then
        grep -o '"state": *"[^"]*"' "$RAMUP_STATE" | cut -d'"' -f4
    else
        echo "inactive"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# MEMORY SUMMARY
# ═══════════════════════════════════════════════════════════════════════════════

show_memory_summary() {
    local total_ram zram_size swap_size effective gained compression
    total_ram=$(get_total_ram_mb)
    zram_size=$(get_zram_size_mb 2>/dev/null || echo "0")
    swap_size=$(get_swap_size_mb 2>/dev/null || echo "0")
    effective=$((total_ram + zram_size + swap_size))
    gained=$((zram_size + swap_size))
    compression=$(get_compression_ratio 2>/dev/null || echo "0")
    
    local ram_pct=0
    local used_ram
    used_ram=$(get_used_ram_mb)
    [[ "$total_ram" -gt 0 ]] && ram_pct=$((used_ram * 100 / total_ram))
    
    echo -e "${CYAN}  ┌──────────────────────────────────────────────┐${NC}"
    echo -e "${CYAN}  │${NC}  🟢 ${BOLD}RAMUP Status${NC}  ${DIM}v${VERSION}${NC}                        ${CYAN}│${NC}"
    echo -e "${CYAN}  ├──────────────────────────────────────────────┤${NC}"
    
    # RAM bar
    local bar_len=20
    local filled=$((ram_pct * bar_len / 100))
    local empty=$((bar_len - filled))
    local bar_color="$GREEN"
    [[ "$ram_pct" -gt 70 ]] && bar_color="$YELLOW"
    [[ "$ram_pct" -gt 90 ]] && bar_color="$RED"
    local bar=""
    for ((i=0; i<filled; i++)); do bar+="█"; done
    for ((i=0; i<empty; i++)); do bar+="░"; done
    
    printf "${CYAN}  │${NC}  Physical RAM:  ${WHITE}%-6s MB${NC}  ${bar_color}[%s]${NC} ${WHITE}%d%%${NC}   ${CYAN}│${NC}\n" "$total_ram" "$bar" "$ram_pct"
    printf "${CYAN}  │${NC}  ZRAM Active:   ${GREEN}%-6s MB${NC}  ${DIM}(%s:1 compression)${NC}  ${CYAN}│${NC}\n" "$zram_size" "$compression"
    printf "${CYAN}  │${NC}  Swap File:     ${GREEN}%-6s MB${NC}                         ${CYAN}│${NC}\n" "$swap_size"
    echo -e "${CYAN}  │${NC}  ${DIM}─────────────────────────────────────────${NC}    ${CYAN}│${NC}"
    printf "${CYAN}  │${NC}  Effective RAM: ${GREEN}${BOLD}~%-5s MB${NC}  🚀                  ${CYAN}│${NC}\n" "$effective"
    printf "${CYAN}  │${NC}  RAM Gained:    ${GREEN}+%-5s MB${NC}  📈                  ${CYAN}│${NC}\n" "$gained"
    
    # Auto-adjust status
    local daemon_status="Inactive"
    local daemon_icon="●"
    if systemctl is-active --quiet ramup-adjust.service 2>/dev/null; then
        daemon_status="Active"
        daemon_icon="${GREEN}●${NC}"
    else
        daemon_icon="${RED}●${NC}"
    fi
    echo -e "${CYAN}  │${NC}  Auto-Adjust:   ${daemon_icon} ${daemon_status}                       ${CYAN}│${NC}"
    
    echo -e "${CYAN}  └──────────────────────────────────────────────┘${NC}"
}

